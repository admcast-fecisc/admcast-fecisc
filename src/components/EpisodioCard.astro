---
const { episodio } = Astro.props;

const data = new Date(episodio.dataPublicacao).toLocaleDateString('pt-BR', {
  day: '2-digit', month: 'long', year: 'numeric'
});

// Extrai o ID do vídeo do YouTube a partir de qualquer formato de URL
function getYoutubeId(url) {
  if (!url) return null;
  const regExp = /(?:youtube\.com\/(?:watch\?v=|embed\/|shorts\/)|youtu\.be\/)([a-zA-Z0-9_-]{11})/;
  const match = url.match(regExp);
  return match ? match[1] : null;
}

const youtubeId = getYoutubeId(episodio.linkYoutube);
---

<article class="ep-card">

  {youtubeId ? (
    <div class="ep-video">
      <iframe
        src={`https://www.youtube.com/embed/${youtubeId}`}
        title={episodio.titulo}
        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
        allowfullscreen
        loading="lazy"
      ></iframe>
    </div>
  ) : episodio.capa ? (
    <div class="ep-capa">
      <img src={episodio.capa} alt={`Capa – ${episodio.titulo}`} loading="lazy" />
      <div class="ep-num">Ep. {episodio.numero}</div>
    </div>
  ) : (
    <div class="ep-capa">
      <div class="ep-capa-placeholder">
        <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M12 2a3 3 0 0 0-3 3v7a3 3 0 0 0 6 0V5a3 3 0 0 0-3-3z"/>
          <path d="M19 10v2a7 7 0 0 1-14 0v-2M12 19v3M8 22h8"/>
        </svg>
      </div>
      <div class="ep-num">Ep. {episodio.numero}</div>
    </div>
  )}

  <div class="ep-body">

    <div class="ep-top">
      <div class="ep-num-inline">Ep. {episodio.numero}</div>
      {episodio.duracao && <div class="ep-duracao">{episodio.duracao}</div>}
    </div>

    {episodio.tags.length > 0 && (
      <div class="ep-tags">
        {episodio.tags.slice(0, 3).map((tag) => (
          <span class="ep-tag">{tag}</span>
        ))}
      </div>
    )}

    <h3 class="ep-titulo">{episodio.titulo}</h3>
    <p class="ep-desc">{episodio.descricao}</p>

    <div class="ep-meta">{data}</div>

    <div class="ep-links">
      {episodio.linkSpotify && (
        <a href={episodio.linkSpotify} target="_blank" rel="noopener" class="ep-btn ep-btn-spotify">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 2C6.477 2 2 6.477 2 12s4.477 10 10 10 10-4.477 10-10S17.523 2 12 2zm4.586 14.424a.622.622 0 0 1-.857.207c-2.348-1.435-5.304-1.76-8.785-.964a.622.622 0 1 1-.277-1.215c3.809-.87 7.077-.496 9.712 1.115a.622.622 0 0 1 .207.857zm1.224-2.722a.779.779 0 0 1-1.072.257c-2.687-1.652-6.785-2.131-9.965-1.166a.78.78 0 0 1-.973-.519.779.779 0 0 1 .519-.972c3.632-1.102 8.147-.568 11.234 1.328a.78.78 0 0 1 .257 1.072zm.105-2.835C14.692 8.95 9.375 8.775 6.297 9.71a.935.935 0 1 1-.543-1.79c3.532-1.072 9.404-.865 13.115 1.338a.935.935 0 0 1-.954 1.609z"/>
          </svg>
          Ouvir no Spotify
        </a>
      )}
      {episodio.linkYoutube && (
        <a href={episodio.linkYoutube} target="_blank" rel="noopener" class="ep-btn ep-btn-youtube">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
            <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
          </svg>
          Ver no YouTube
        </a>
      )}
    </div>

  </div>
</article>

<style>
  .ep-card {
    background: var(--white);
    border-radius: 18px;
    border: 1px solid rgba(0,0,0,0.07);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    transition: transform 0.2s, box-shadow 0.2s;
  }
  .ep-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 40px rgba(232,93,38,0.12);
  }

  /* Player YouTube */
  .ep-video {
    position: relative;
    aspect-ratio: 16/9;
    background: #000;
    overflow: hidden;
  }
  .ep-video iframe {
    width: 100%;
    height: 100%;
    border: none;
    display: block;
  }

  /* Capa fallback */
  .ep-capa {
    position: relative;
    aspect-ratio: 16/9;
    background: var(--dark);
    overflow: hidden;
  }
  .ep-capa img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .ep-capa-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: rgba(255,255,255,0.2);
  }
  .ep-num {
    position: absolute;
    top: 10px;
    left: 10px;
    background: var(--orange);
    color: white;
    font-size: 11px;
    font-weight: 600;
    padding: 3px 10px;
    border-radius: 100px;
    font-family: 'Syne', sans-serif;
  }

  /* Body */
  .ep-body {
    padding: 1.2rem 1.3rem 1.5rem;
    display: flex;
    flex-direction: column;
    flex: 1;
  }
  .ep-top {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 0.8rem;
  }
  .ep-num-inline {
    background: var(--orange);
    color: white;
    font-size: 11px;
    font-weight: 600;
    padding: 3px 10px;
    border-radius: 100px;
    font-family: 'Syne', sans-serif;
  }
  .ep-duracao {
    font-size: 12px;
    color: var(--gray);
    background: rgba(0,0,0,0.05);
    padding: 3px 10px;
    border-radius: 100px;
  }
  .ep-tags {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
    margin-bottom: 0.7rem;
  }
  .ep-tag {
    background: var(--orange-pale);
    color: var(--orange);
    font-size: 11px;
    padding: 3px 10px;
    border-radius: 100px;
    font-weight: 500;
  }
  .ep-titulo {
    font-family: 'Syne', sans-serif;
    font-weight: 700;
    font-size: 1rem;
    letter-spacing: -0.3px;
    color: var(--dark);
    margin-bottom: 0.6rem;
    line-height: 1.3;
  }
  .ep-desc {
    font-size: 13px;
    color: var(--gray);
    line-height: 1.6;
    flex: 1;
    margin-bottom: 1rem;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .ep-meta {
    font-size: 12px;
    color: var(--gray);
    margin-bottom: 1rem;
  }
  .ep-links {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
  }
  .ep-btn {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 7px 14px;
    border-radius: 100px;
    font-size: 12px;
    font-weight: 500;
    text-decoration: none;
    transition: opacity 0.2s;
  }
  .ep-btn:hover { opacity: 0.85; }
  .ep-btn-spotify { background: #1DB954; color: white; }
  .ep-btn-youtube { background: #FF0000; color: white; }
</style>
